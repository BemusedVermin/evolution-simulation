{
  "id": "apply_locomotive_thrust",
  "category": "force_application",
  "description": "Applies sustained locomotive thrust (swimming, running, flying) at specified magnitude. Enables movement, escape, and pursuit. Cost scales linearly with thrust and duration.",
  "parameter_schema": {
    "thrust_n": {
      "type": "number",
      "range": {
        "min": 1,
        "max": 10000
      },
      "units": "newtons",
      "default": 100
    },
    "duration_ms": {
      "type": "number",
      "range": {
        "min": 100,
        "max": 60000
      },
      "units": "milliseconds",
      "default": 5000
    },
    "body_site": {
      "type": "string"
    }
  },
  "composition_compatibility": [
    {
      "channel_family": "motor"
    },
    {
      "channel_family": "metabolic"
    }
  ],
  "cost_function": {
    "base_metabolic_cost": 1.8,
    "parameter_scaling": [
      {
        "parameter": "thrust_n",
        "exponent": 1.0,
        "coefficient": 0.003
      },
      {
        "parameter": "duration_ms",
        "exponent": 1.0,
        "coefficient": 0.0002
      }
    ]
  },
  "observable_signature": {
    "modality": "mechanical",
    "detection_range_m": 50,
    "pattern_key": "locomotion_v1"
  },
  "provenance": "core"
}
