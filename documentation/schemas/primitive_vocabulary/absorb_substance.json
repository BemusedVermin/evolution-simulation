    "parameter_scaling": [
      {
        "parameter": "rate_ml_per_s",
        "exponent": 1.0,
        "coefficient": 0.2
      },
      {
        "parameter": "selectivity",
        "exponent": 2.0,
        "coefficient": 0.1
      }
    ]
  },
  "observable_signature": {
    "modality": "chemical",
    "detection_range_m": 0,
